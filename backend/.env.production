# ─── Production Environment Template ───
# Copy this file to .env and fill in production values

# Database
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/siteos?retryWrites=true&w=majority

# Server
PORT=3000
NODE_ENV=production

# JWT — CHANGE THIS IN PRODUCTION
JWT_SECRET=<generate-a-strong-64-char-random-string>
JWT_EXPIRES_IN=7d

# CORS — Set to your production frontend domain
CORS_ORIGIN=https://yourdomain.com
